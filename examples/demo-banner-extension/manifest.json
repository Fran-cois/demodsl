{
  "manifest_version": 3,
  "name": "DemoDSL Demo Banner",
  "version": "1.0.0",
  "description": "Injects a visual DEMO MODE banner for product demos.",
  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
